RewriteEngine On

# API front controller
RewriteRule ^api/(.*)$ api.php [QSA,L]

# Pretty URL for register page
RewriteRule ^register$ register.php [QSA,L]

# Pretty URL for login page
RewriteRule ^login$ login.php [QSA,L]

# Pretty URL for create item page
RewriteRule ^create-item$ create-item.php [QSA,L]

# Pretty URL for seller dashboard
RewriteRule ^seller-dashboard$ seller-dashboard.php [QSA,L]

# Pretty URL for buyer dashboard
RewriteRule ^buyer-dashboard$ buyer-dashboard.php [QSA,L]

# SEO-friendly item details page
RewriteRule ^item/([^/]+)$ item.php?seo_slug=$1 [QSA,L]

# Existing files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback to index
RewriteRule ^ index.php [QSA,L]
